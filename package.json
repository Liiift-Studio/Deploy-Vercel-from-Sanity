{
  "name": "@liiift-studio/deploy-vercel-from-sanity",
  "version": "0.1.7",
  "description": "Sanity Studio v5 plugin — trigger and monitor Vercel deployments with full status, history, and build logs",
  "license": "MIT",
  "author": "Liiift Studio",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "vercel",
    "deploy",
    "deployment"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "sanity": ">=5"
  },
  "devDependencies": {
    "@sanity/icons": "^3",
    "@sanity/ui": "^3",
    "@types/react": "^19",
    "react": "^19",
    "sanity": "^5",
    "tsup": "^8",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Liiift-Studio/Deploy-Vercel-from-Sanity"
  }
}
